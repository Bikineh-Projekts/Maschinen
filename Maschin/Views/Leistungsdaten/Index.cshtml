@using MaschinenDataein.Models.ModelView
@model List<LeistungsdatenModelView>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["actionForm"] = "Index";
    ViewData["Title"] = "Leistungsdaten";
    ViewData["IsShowId"] = true;
}

<div class="container-fluid mt-4">
    <h1 class="mb-3 text-center">⚡ Leistungsdaten</h1>

    @await Html.PartialAsync("_PartialFilter")

    @* Tab-Navigation *@
    <ul class="nav nav-tabs mb-3" id="leistungTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="tabelle-tab"
                    data-bs-toggle="tab" data-bs-target="#leistTabelle"
                    type="button" role="tab">
                📋 Tabelle
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="chart-tab"
                    data-bs-toggle="tab" data-bs-target="#leistChart"
                    type="button" role="tab"
                    onclick="ladeLeistungChart()">
                📊 Leistungs-Analyse
            </button>
        </li>
    </ul>

    <div class="tab-content">

        @* TAB 1: Tabelle *@
        <div class="tab-pane fade show active" id="leistTabelle" role="tabpanel">
            @await Html.PartialAsync("_LeistungsdatenTable", Model)
        </div>

        @* TAB 2: Chart *@
        <div class="tab-pane fade" id="leistChart" role="tabpanel">
            @await Html.PartialAsync("_LeistungsdatenChart")
        </div>

    </div>
</div>
