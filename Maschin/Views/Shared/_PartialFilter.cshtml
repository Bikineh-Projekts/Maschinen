@using MaschinenDataein.Models.ModelView
@{
    FilterModelView filterModelView = ViewBag.FilterView as FilterModelView;
}

@if (filterModelView != null)
{
    <form asp-action="Filter" asp-controller="@filterModelView.ControllerName" method="post">
        @Html.AntiForgeryToken()
        @Html.Hidden("ActionForm",      filterModelView.ActionForm      ?? "Index")
        @Html.Hidden("ControllerName",  filterModelView.ControllerName)

        @* ── Hidden fields für Datum ─────────────────────────────────────────
           Werden von updateDate() bei jedem Dropdown-Change aktualisiert
           UND beim Seitenaufruf direkt mit dem Cookie-Wert vorbelegt.       *@
        <input type="hidden" id="DatumVon" name="DatumVon"
               value="@filterModelView.DatumVon.ToString("yyyy-MM-dd")" />
        <input type="hidden" id="DatumBis" name="DatumBis"
               value="@filterModelView.DatumBis.ToString("yyyy-MM-dd")" />

        <div class="row mb-3">

            @* ── Maschine ────────────────────────────────────────────────── *@
            <div class="col-md-4">
                <label class="form-label">Maschinenauswahl</label>
                @Html.DropDownList("MaschinenId",
                    (IEnumerable<SelectListItem>)(ViewBag.Maschinen ?? new List<SelectListItem>()),
                    new { @class = "form-select", id = "MaschinenId" })
            </div>

            @* ── Startdatum ──────────────────────────────────────────────── *@
            <div class="col-md-4">
                <label class="form-label">Startdatum</label>
                <div class="d-flex gap-1">
                    <select id="vonDay" class="form-select" onchange="updateDate('Von')">
                        @for (int d = 1; d <= 31; d++)
                        {
                            <option value="@d" @(d == filterModelView.DatumVon.Day ? "selected" : "")>
                                @d.ToString("D2")
                            </option>
                        }
                    </select>
                    <select id="vonMonth" class="form-select" onchange="updateDate('Von')">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m" @(m == filterModelView.DatumVon.Month ? "selected" : "")>
                                @m.ToString("D2")
                            </option>
                        }
                    </select>
                    <select id="vonYear" class="form-select" onchange="updateDate('Von')">
                        @for (int y = DateTime.Now.Year - 3; y <= DateTime.Now.Year + 1; y++)
                        {
                            <option value="@y" @(y == filterModelView.DatumVon.Year ? "selected" : "")>
                                @y
                            </option>
                        }
                    </select>
                </div>
            </div>

            @* ── Enddatum ────────────────────────────────────────────────── *@
            <div class="col-md-4">
                <label class="form-label">Enddatum</label>
                <div class="d-flex gap-1">
                    <select id="bisDay" class="form-select" onchange="updateDate('Bis')">
                        @for (int d = 1; d <= 31; d++)
                        {
                            <option value="@d" @(d == filterModelView.DatumBis.Day ? "selected" : "")>
                                @d.ToString("D2")
                            </option>
                        }
                    </select>
                    <select id="bisMonth" class="form-select" onchange="updateDate('Bis')">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m" @(m == filterModelView.DatumBis.Month ? "selected" : "")>
                                @m.ToString("D2")
                            </option>
                        }
                    </select>
                    <select id="bisYear" class="form-select" onchange="updateDate('Bis')">
                        @for (int y = DateTime.Now.Year - 3; y <= DateTime.Now.Year + 1; y++)
                        {
                            <option value="@y" @(y == filterModelView.DatumBis.Year ? "selected" : "")>
                                @y
                            </option>
                        }
                    </select>
                </div>
            </div>

        </div>

        <div class="mb-3 text-end">
            <button type="submit" class="btn btn-primary">Filtern</button>
            <a href="@Url.Action("Index", filterModelView.ControllerName)"
               class="btn btn-secondary">Zurücksetzen</a>
        </div>
    </form>
}
else
{
    <div class="alert alert-warning">
        ⚠️ Filter konnte nicht geladen werden. Bitte Seite neu laden.
    </div>
}

<script>
    // ── Datum aus Dropdowns zusammenbauen und ins hidden field schreiben ──────
    function updateDate(which) {
        var w     = which.toLowerCase();
        var day   = parseInt(document.getElementById(w + 'Day').value);
        var month = parseInt(document.getElementById(w + 'Month').value);
        var year  = parseInt(document.getElementById(w + 'Year').value);
        var mm    = String(month).padStart(2, '0');
        var dd    = String(day).padStart(2, '0');
        document.getElementById('Datum' + which).value = year + '-' + mm + '-' + dd;
    }

    // ── FIX: Beim Seitenaufruf SOFORT beide hidden fields synchronisieren ─────
    //
    // Problem vorher:
    //   Die hidden fields wurden NUR bei onchange befüllt.
    //   Beim ersten Laden ohne Filter-Klick stimmten sie mit den
    //   Dropdowns überein — aber jedes JS das document.getElementById('DatumVon')
    //   las, bekam den Wert aus dem letzten Cookie, nicht den aktuellen Dropdown.
    //   Bei Datum-Änderung ohne Filtern-Klick war der Wert falsch.
    //
    // Lösung:
    //   Beim DOMContentLoaded werden beide Felder sofort neu berechnet,
    //   sodass sie immer mit den sichtbaren Dropdowns übereinstimmen.
    //
    document.addEventListener('DOMContentLoaded', function () {
        updateDate('Von');
        updateDate('Bis');
    });
</script>
