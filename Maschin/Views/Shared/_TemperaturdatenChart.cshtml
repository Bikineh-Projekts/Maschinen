@*
    _TemperaturdatenChart.cshtml  ── Temperatur-Analyse-Dashboard
    Lädt Daten von: GET /TemperaturDaten/GetChartData
    Liest Filter direkt aus den DOM-Elementen der _PartialFilter
    Verwendet: Chart.js 4.4.1 (stabiler CDN)
*@

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

<style>
    .td-dashboard {
        background: #0d1117;
        border-radius: 14px;
        padding: 24px;
        color: #e6edf3;
        font-family: 'Segoe UI', system-ui, sans-serif;
        min-height: 400px;
    }
    .td-stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(148px, 1fr));
        gap: 12px;
        margin-bottom: 20px;
    }
    .td-stat-card {
        background: #1c2128;
        border: 1px solid #30363d;
        border-radius: 10px;
        padding: 14px 18px;
    }
    .td-stat-label {
        font-size: 10px;
        color: #8b949e;
        text-transform: uppercase;
        letter-spacing: 1.1px;
        margin-bottom: 4px;
    }
    .td-stat-value {
        font-size: 26px;
        font-weight: 700;
        font-family: 'Courier New', monospace;
    }
    .td-stat-unit { font-size: 13px; margin-left: 3px; color: #8b949e; }
    .td-stat-sub  { font-size: 10px; color: #8b949e; margin-top: 3px; }
    .td-chart-box {
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: 12px;
        padding: 16px 16px 10px;
        margin-bottom: 14px;
    }
    .td-chart-title { font-size: 12px; color: #8b949e; margin-bottom: 12px; }
    .td-btns { display: flex; gap: 6px; margin-bottom: 16px; flex-wrap: wrap; }
    .td-btn {
        padding: 7px 16px;
        border-radius: 8px;
        border: 1px solid #30363d;
        background: transparent;
        color: #8b949e;
        cursor: pointer;
        font-size: 13px;
        transition: all 0.15s;
    }
    .td-btn.k-active {
        background: #58a6ff22;
        border-color: #58a6ff;
        color: #58a6ff;
        font-weight: 600;
    }
    .td-btn.a-active {
        background: #3fb95022;
        border-color: #3fb950;
        color: #3fb950;
        font-weight: 600;
    }
    .td-info {
        background: #1c2128;
        border: 1px solid #30363d;
        border-radius: 10px;
        padding: 12px 16px;
        font-size: 12px;
        color: #8b949e;
        line-height: 1.7;
    }
    .td-info b { color: #e6edf3; display: block; margin-bottom: 5px; }
    .td-loader {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 220px;
        color: #8b949e;
        font-size: 14px;
        gap: 10px;
    }
    .td-spin {
        width: 20px; height: 20px;
        border: 2px solid #30363d;
        border-top-color: #58a6ff;
        border-radius: 50%;
        animation: tdspin 0.8s linear infinite;
    }
    @@keyframes tdspin { to { transform: rotate(360deg); } }
    .td-empty {
        padding: 32px;
        color: #8b949e;
        font-size: 14px;
        text-align: center;
        line-height: 1.8;
    }
    .td-debug {
        margin-top: 12px;
        padding: 10px 14px;
        background: #1c2128;
        border: 1px solid #30363d;
        border-radius: 8px;
        font-family: monospace;
        font-size: 11px;
        color: #555;
        text-align: left;
    }
    .td-reload-btn {
        margin-top: 14px;
        padding: 8px 22px;
        background: #58a6ff22;
        border: 1px solid #58a6ff;
        color: #58a6ff;
        border-radius: 8px;
        cursor: pointer;
        font-size: 13px;
    }
</style>

<div id="tdRoot" class="td-dashboard">
    <div class="td-loader">
        <div class="td-spin"></div>
        Lade Temperaturdaten ...
    </div>
</div>

<script>
(function () {

    // ── State ────────────────────────────────────────────────────────────────
    let _daten    = null;
    let _kanal    = 1;
    let _ansicht  = 'verlauf';
    let _chart    = null;

    // ── Farben ───────────────────────────────────────────────────────────────
    const C = {
        soll:   '#58a6ff',
        ist:    '#f0883e',
        fehler: '#3fb950',
        neg:    '#f85149',
        warn:   '#e3b341',
        muted:  '#8b949e',
        border: '#30363d',
        purple: '#c0a4ff',
    };

    // ════════════════════════════════════════════════════════════════════════
    // Filter-Werte lesen
    //
    // _PartialFilter hat hidden fields:
    //   <input type="hidden" id="DatumVon" value="yyyy-MM-dd" />
    //   <input type="hidden" id="DatumBis" value="yyyy-MM-dd" />
    //
    // updateDate() in _PartialFilter aktualisiert diese automatisch
    // wenn der User einen Dropdown ändert.
    // Wir lesen einfach diese hidden fields — fertig, kein DOM-Raten mehr.
    // ════════════════════════════════════════════════════════════════════════
    function leseFilter() {
        // Hidden fields aus _PartialFilter direkt lesen
        // Diese werden von updateDate() aktuell gehalten
        const datumVon    = document.getElementById('DatumVon')?.value    || '';
        const datumBis    = document.getElementById('DatumBis')?.value    || '';
        const maschinenId = document.getElementById('MaschinenId')?.value || '0';

        return { datumVon, datumBis, maschinenId };
    }

    // Daten laden — öffentliche Funktion, aufgerufen vom Tab-onclick
    // ════════════════════════════════════════════════════════════════════════
    window.ladeChartDaten = function (force) {
        if (_daten && !force) return;
        _daten = null;

        document.getElementById('tdRoot').innerHTML =
            '<div class="td-loader"><div class="td-spin"></div>Lade Temperaturdaten ...</div>';

        const f  = leseFilter();
        const qs = [];
        if (f.datumVon)                      qs.push('datumVon='    + encodeURIComponent(f.datumVon));
        if (f.datumBis)                      qs.push('datumBis='    + encodeURIComponent(f.datumBis));
        if (f.maschinenId && f.maschinenId !== '0')
                                             qs.push('maschinenId=' + encodeURIComponent(f.maschinenId));

        const url = '/TemperaturDaten/GetChartData' + (qs.length ? '?' + qs.join('&') : '');

        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(r => {
                if (!r.ok) throw new Error('Server antwortete mit HTTP ' + r.status);
                return r.json();
            })
            .then(json => {
                _daten = json;

                if (!json.punkte || json.punkte.length === 0) {
                    const dbg = json.debug || {};
                    document.getElementById('tdRoot').innerHTML = `
                        <div class="td-empty">
                            <div style="font-size:36px;margin-bottom:12px">📭</div>
                            <div style="font-size:16px;color:#e6edf3;margin-bottom:8px">
                                Keine Daten im gewählten Zeitraum
                            </div>
                            <div style="font-size:13px">
                                Bitte Datumsbereich oder Maschine anpassen,
                                <strong style="color:#58a6ff">Filtern</strong> klicken
                                und danach erneut auf
                                <strong style="color:#3fb950">📊 Analyse-Diagramm</strong> wechseln.
                            </div>
                            <div class="td-debug">
                                🔍 Abgefragter Zeitraum:
                                <span style="color:#58a6ff">${dbg.datumVonVerwendet || '?'}</span>
                                bis
                                <span style="color:#58a6ff">${dbg.datumBisVerwendet || '?'}</span>
                                &nbsp;·&nbsp; Maschinen-ID:
                                <span style="color:#f0883e">${dbg.maschinenIdFilter || 'alle'}</span>
                                &nbsp;·&nbsp; Datenbankzeilen:
                                <span style="color:#f85149">${dbg.gesamtPunkteDatenbank ?? 0}</span>
                            </div>
                            <button class="td-reload-btn" onclick="ladeChartDaten(true)">🔄 Neu laden</button>
                        </div>`;
                    return;
                }

                renderDashboard();
            })
            .catch(err => {
                document.getElementById('tdRoot').innerHTML = `
                    <div class="td-empty">
                        <div style="font-size:32px;margin-bottom:10px;color:#f85149">❌</div>
                        <div style="font-size:15px;color:#e6edf3;margin-bottom:6px">Fehler beim Laden</div>
                        <div class="td-debug" style="color:#f85149">
                            ${err.message}<br>
                            <span style="color:#555">Endpoint: ${url}</span>
                        </div>
                        <div style="margin-top:10px;font-size:12px;color:#8b949e">
                            Prüfe ob <code style="color:#f0883e">GetChartData</code>
                            im Controller existiert und die App läuft.
                        </div>
                        <button class="td-reload-btn" style="border-color:#f85149;color:#f85149;background:#f8514911"
                            onclick="ladeChartDaten(true)">🔄 Erneut versuchen</button>
                    </div>`;
            });
    };

    // ════════════════════════════════════════════════════════════════════════
    // Histogramm-Daten berechnen
    // ════════════════════════════════════════════════════════════════════════
    function buildHist(key) {
        const bins = {};
        for (let b = -8; b <= 8; b++) bins[b] = 0;
        _daten.punkte.forEach(p => {
            const b = Math.round(Math.max(-8, Math.min(8, p[key])));
            if (b in bins) bins[b]++;
        });
        return {
            labels: Object.keys(bins).map(k => k + '°C'),
            counts: Object.values(bins)
        };
    }

    // ════════════════════════════════════════════════════════════════════════
    // Chart zeichnen
    // ════════════════════════════════════════════════════════════════════════
    function drawChart() {
        if (_chart) { _chart.destroy(); _chart = null; }

        const canvas = document.getElementById('tdCanvas');
        if (!canvas) return;

        const sollKey   = _kanal === 1 ? 'soll1'   : 'soll2';
        const istKey    = _kanal === 1 ? 'ist1'    : 'ist2';
        const fehlerKey = _kanal === 1 ? 'fehler1' : 'fehler2';
        const punkte    = _daten.punkte;
        const labels    = punkte.map(p => p.t);
        const s         = _kanal === 1 ? _daten.statistik.kanal1 : _daten.statistik.kanal2;

        Chart.defaults.color = C.muted;

        const baseOpts = {
            responsive: true,
            maintainAspectRatio: false,
            animation: { duration: 250 },
            plugins: {
                legend: { labels: { color: C.muted, font: { size: 12 }, boxWidth: 20 } },
                tooltip: {
                    backgroundColor: '#0d1117ee',
                    borderColor: C.border,
                    borderWidth: 1,
                    titleColor: C.muted,
                    bodyColor: '#e6edf3',
                    callbacks: { label: c => ` ${c.dataset.label}: ${c.parsed.y}°C` }
                }
            },
            scales: {
                x: {
                    ticks: { color: C.muted, maxTicksLimit: 10, font: { size: 10 } },
                    grid:  { color: C.border + '55' }
                },
                y: {
                    ticks: { color: C.muted, font: { size: 10 } },
                    grid:  { color: C.border + '55' },
                    title: { display: true, text: '°C', color: C.muted }
                }
            }
        };

        if (_ansicht === 'verlauf') {
            _chart = new Chart(canvas.getContext('2d'), {
                type: 'line',
                data: {
                    labels,
                    datasets: [
                        {
                            label: `Soll${_kanal}`,
                            data: punkte.map(p => p[sollKey]),
                            borderColor: C.soll,
                            backgroundColor: C.soll + '18',
                            borderDash: [6, 3],
                            borderWidth: 2,
                            pointRadius: 0,
                            fill: true,
                            tension: 0.3
                        },
                        {
                            label: `Ist${_kanal}`,
                            data: punkte.map(p => p[istKey]),
                            borderColor: C.ist,
                            backgroundColor: 'transparent',
                            borderWidth: 2,
                            pointRadius: 0,
                            tension: 0.3
                        }
                    ]
                },
                options: baseOpts
            });

        } else if (_ansicht === 'fehler') {
            _chart = new Chart(canvas.getContext('2d'), {
                type: 'line',
                data: {
                    labels,
                    datasets: [
                        {
                            label: `Fehler Kanal${_kanal}`,
                            data: punkte.map(p => p[fehlerKey]),
                            borderColor: C.fehler,
                            backgroundColor: C.fehler + '22',
                            borderWidth: 1.5,
                            pointRadius: 0,
                            fill: true,
                            tension: 0.2
                        },
                        {
                            label: `Bias (${s.bias}°C)`,
                            data: labels.map(() => s.bias),
                            borderColor: C.warn,
                            borderDash: [5, 4],
                            borderWidth: 1.5,
                            pointRadius: 0,
                            fill: false
                        },
                        {
                            label: 'Nulllinie',
                            data: labels.map(() => 0),
                            borderColor: '#ffffff22',
                            borderWidth: 1,
                            pointRadius: 0,
                            fill: false
                        }
                    ]
                },
                options: {
                    ...baseOpts,
                    scales: {
                        ...baseOpts.scales,
                        y: { ...baseOpts.scales.y, title: { display: true, text: 'ΔT (°C)', color: C.muted } }
                    }
                }
            });

        } else if (_ansicht === 'histogramm') {
            const hist = buildHist(fehlerKey);
            _chart = new Chart(canvas.getContext('2d'), {
                type: 'bar',
                data: {
                    labels: hist.labels,
                    datasets: [{
                        label: 'Häufigkeit',
                        data: hist.counts,
                        backgroundColor: C.soll + 'bb',
                        borderColor: C.soll,
                        borderWidth: 1,
                        borderRadius: 4
                    }]
                },
                options: {
                    ...baseOpts,
                    scales: {
                        x: { ...baseOpts.scales.x, title: { display: true, text: 'Fehler (°C)', color: C.muted } },
                        y: { ...baseOpts.scales.y, title: { display: true, text: 'Anzahl', color: C.muted } }
                    }
                }
            });
        }
    }

    // ════════════════════════════════════════════════════════════════════════
    // Interpretation
    // ════════════════════════════════════════════════════════════════════════
    function interpText() {
        const s = _kanal === 1 ? _daten.statistik.kanal1 : _daten.statistik.kanal2;
        const ab = Math.abs(s.bias);

        const bColor = ab < 1 ? C.fehler : ab < 3 ? C.warn : C.neg;
        const bText  = ab < 1 ? '✅ Sehr gute Kalibrierung'
                     : ab < 3 ? '⚠️ Leichte Abweichung — Sensor-Kalibrierung prüfen'
                     :          '❌ Systematischer Fehler — Heizung/Sensor defekt?';

        const rColor = s.rmse < 2 ? C.fehler : s.rmse < 5 ? C.warn : C.neg;
        const rText  = s.rmse < 2 ? '✅ Stabile Regelung'
                     : s.rmse < 5 ? '⚠️ Mäßige Stabilität'
                     :              '❌ Instabile Regelung — PID prüfen';

        const dbg = _daten.debug || {};

        return `
            <div class="td-info">
                <b>💡 Automatische Interpretation — Kanal ${_kanal}</b>
                Bias: <strong style="color:${bColor}">${s.bias}°C</strong> → ${bText}
                &nbsp;·&nbsp;
                RMSE: <strong style="color:${rColor}">${s.rmse}°C</strong> → ${rText}
                <div style="margin-top:8px;font-size:10px;color:#444">
                    Zeitraum: ${dbg.datumVonVerwendet || '–'} – ${dbg.datumBisVerwendet || '–'}
                    &nbsp;·&nbsp; Datenbankpunkte: ${dbg.gesamtPunkteDatenbank ?? '–'}
                    &nbsp;·&nbsp; Dargestellt: ${dbg.dargestelltePunkte ?? _daten.punkte.length}
                </div>
            </div>`;
    }

    // ════════════════════════════════════════════════════════════════════════
    // Dashboard komplett rendern
    // ════════════════════════════════════════════════════════════════════════
    function renderDashboard() {
        const s = _kanal === 1 ? _daten.statistik.kanal1 : _daten.statistik.kanal2;

        function sc(label, value, unit, color, sub) {
            return `<div class="td-stat-card">
                <div class="td-stat-label">${label}</div>
                <div class="td-stat-value" style="color:${color}">
                    ${value}<span class="td-stat-unit">${unit}</span>
                </div>
                <div class="td-stat-sub">${sub}</div>
            </div>`;
        }

        const kBtns = [1,2].map(k =>
            `<button class="td-btn${_kanal===k?' k-active':''}" onclick="tdKanal(${k})">
                Kanal ${k} &nbsp;(Soll${k} / Ist${k})
             </button>`
        ).join('');

        const aBtns = [
            { id:'verlauf',    l:'Soll / Ist Verlauf' },
            { id:'fehler',     l:'Fehler-Verlauf'     },
            { id:'histogramm', l:'Histogramm'         },
        ].map(a =>
            `<button class="td-btn${_ansicht===a.id?' a-active':''}" onclick="tdAnsicht('${a.id}')">
                ${a.l}
             </button>`
        ).join('');

        const titles = {
            verlauf    : 'Soll-Temperatur (Zielkurve) vs. Ist-Temperatur — Abstand = Regelabweichung',
            fehler     : `Fehler(t) = Ist${_kanal}(t) − Soll${_kanal}(t) &nbsp;·&nbsp; Positiv = zu warm &nbsp;·&nbsp; Negativ = zu kalt`,
            histogramm : 'Häufigkeitsverteilung der Fehler — Ideal: schmale Glocke zentriert um 0°C'
        };

        document.getElementById('tdRoot').innerHTML = `
            <div style="margin-bottom:18px">
                <h4 style="margin:0 0 4px;font-weight:700">🌡 Temperatur-Analyse</h4>
                <p style="margin:0;color:#8b949e;font-size:13px">
                    ${_daten.punkte.length} Messpunkte · Kanal ${_kanal} aktiv
                </p>
            </div>

            <div class="td-btns">${kBtns}</div>

            <div class="td-stat-grid">
                ${sc('Bias (Mittelwert)', s.bias,      '°C', s.bias>=0 ? C.ist : C.neg, 'Systematische Abweichung')}
                ${sc('RMSE',             s.rmse,      '°C', C.purple,                  'Ø Quadratischer Fehler'  )}
                ${sc('Std. Abweichung',  s.std,       '°C', C.soll,                    'Rauschen / Instabilität' )}
                ${sc('Max. |Fehler|',    s.maxFehler, '°C', C.neg,                     'Größter Ausreißer'       )}
                ${sc('Messpunkte',       s.anzahl,    '',   C.fehler,                  'im gewählten Zeitraum'   )}
            </div>

            <div class="td-btns">${aBtns}</div>

            <div class="td-chart-box">
                <div class="td-chart-title">${titles[_ansicht]}</div>
                <div style="position:relative;height:320px">
                    <canvas id="tdCanvas"></canvas>
                </div>
            </div>

            ${interpText()}
        `;

        drawChart();
    }

    // ── Öffentliche Umschalter ────────────────────────────────────────────
    window.tdKanal   = k => { _kanal   = k; renderDashboard(); };
    window.tdAnsicht = a => { _ansicht = a; renderDashboard(); };

})();
</script>
