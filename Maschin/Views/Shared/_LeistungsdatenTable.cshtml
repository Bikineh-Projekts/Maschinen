@using MaschinenDataein.Models.ModelView
@model List<LeistungsdatenModelView>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Leistungsdaten";
}

<div class="container-fluid mt-4">

    <h2 class="text-center mb-3">⚡ Leistungsdaten</h2>

    @await Html.PartialAsync("_PartialFilter")

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <button class="nav-link active"
                    data-bs-toggle="tab"
                    data-bs-target="#tableTab">
                📋 Tabelle
            </button>
        </li>

        <li class="nav-item">
            <button class="nav-link"
                    data-bs-toggle="tab"
                    data-bs-target="#chartTab"
                    onclick="loadDashboard()">
                📊 Analyse
            </button>
        </li>
    </ul>

    <div class="tab-content">

        <div class="tab-pane fade show active" id="tableTab">
            @await Html.PartialAsync("_LeistungsdatenTable", Model)
        </div>

        <div class="tab-pane fade" id="chartTab">
            @await Html.PartialAsync("_LeistungsdatenChart")
        </div>

    </div>

</div>
