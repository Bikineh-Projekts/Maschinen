@using MaschinenDataein.Models.ModelView
@using MaschinenDataein.Models.PaginatedModel
@model List<LeistungsdatenModelView>

@{
    bool IsShowId = Convert.ToBoolean(ViewData["IsShowId"]);
    PaginatedListItem? pagInfo = ViewData["PaginatedListItem"] as PaginatedListItem;
}

@if (Model != null && Model.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-bordered table-hover table-sm align-middle mb-0"
               style="font-size:13px">
            <thead class="table-dark text-center">
                <tr>
                    @if (IsShowId)
                    {
                        <th style="width:60px">ID</th>
                    }
                    <th>Zeitstempel</th>
                    <th>Maschine</th>
                    <th>Programm</th>
                    <th>Tagesz.</th>
                    <th>Takte</th>
                    <th>Packungen</th>
                    <th>Takte-Balken</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int maxTakte = Model.Any() ? Model.Max(x => x.Maschinentakte) : 1;
                    if (maxTakte < 1) maxTakte = 1;
                }

                @foreach (var item in Model)
                {
                    int pct = (int)(item.Maschinentakte * 100.0 / maxTakte);

                    string barColor = pct >= 80 ? "#3fb950"
                                    : pct >= 40 ? "#e3b341"
                                    : "#f85149";

                    <tr>
                        @if (IsShowId)
                        {
                            <td class="text-center text-muted">@item.Id</td>
                        }

                        <td class="text-center" style="white-space:nowrap">
                            @item.Timestamp.ToString("dd.MM.yyyy")
                            <span class="text-muted" style="font-size:11px; margin-left:6px;">
                                @item.Timestamp.ToString("HH:mm:ss")
                            </span>
                        </td>

                        <td class="text-center">@(item.Maschine ?? "–")</td>
                        <td>@(string.IsNullOrWhiteSpace(item.Name) ? "–" : item.Name)</td>

                        <td class="text-end">@item.Tagestaktzaehler.ToString("N0")</td>
                        <td class="text-end fw-bold">@item.Maschinentakte.ToString("N0")</td>
                        <td class="text-end">@item.Packungszaehler.ToString("N0")</td>

                        <td style="min-width:100px;padding:6px 10px">
                            <div style="display:flex;align-items:center;gap:6px">
                                <div style="flex:1;height:8px;background:#21262d;border-radius:4px">
                                    <div style="width:@(pct)%;height:100%;background:@barColor;"></div>
                                </div>
                                <span style="font-size:10px;color:#8b949e">
                                    @(pct)%
                                </span>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* 👉 EINZIGE Pagination *@
    @if (pagInfo != null)
    {
        @await Html.PartialAsync("_PaginatedItem", pagInfo)
    }
}
else
{
    <div class="alert alert-info text-center mt-3">
        Keine Daten vorhanden
    </div>
}
