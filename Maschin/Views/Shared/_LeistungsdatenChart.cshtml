<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/hammerjs@2.0.8/hammer.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.0.1/dist/chartjs-plugin-zoom.min.js"></script>

<style>
    .lc-dashboard{background:#0d1117;border-radius:14px;padding:24px;color:#e6edf3;font-family:'Segoe UI',system-ui,sans-serif;}
    .lc-header{margin-bottom:20px;}.lc-header h4{margin:0 0 4px;font-weight:700;font-size:18px;}.lc-header p{margin:0;color:#8b949e;font-size:13px;}
    .lc-stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:20px;}
    .lc-stat{background:#1c2128;border:1px solid #30363d;border-radius:10px;padding:12px 16px;}
    .lc-stat-label{font-size:10px;color:#8b949e;text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;}
    .lc-stat-val{font-size:24px;font-weight:700;font-family:'Courier New',monospace;}
    .lc-stat-sub{font-size:10px;color:#8b949e;margin-top:2px;}
    .lc-tabs{display:flex;gap:4px;margin-bottom:16px;flex-wrap:wrap;}
    .lc-tab-btn{padding:7px 16px;border-radius:8px;border:1px solid #30363d;background:transparent;color:#8b949e;cursor:pointer;font-size:13px;transition:all .15s;}
    .lc-tab-btn.active{background:#58a6ff22;border-color:#58a6ff;color:#58a6ff;font-weight:600;}
    .lc-box{background:#161b22;border:1px solid #30363d;border-radius:12px;padding:16px;margin-bottom:16px;}
    .lc-box-title{font-size:13px;font-weight:600;color:#e6edf3;margin-bottom:4px;}
    .lc-box-hint{font-size:11px;color:#555;margin-bottom:12px;}
    .lc-perf-table{width:100%;border-collapse:collapse;font-size:13px;}
    .lc-perf-table th{padding:8px 12px;font-size:10px;text-transform:uppercase;letter-spacing:.8px;color:#8b949e;border-bottom:1px solid #30363d;background:#1c2128;text-align:left;}
    .lc-perf-table td{padding:10px 12px;border-bottom:1px solid #21262d;color:#e6edf3;}
    .lc-perf-table tr:last-child td{border-bottom:none;}.lc-perf-table tr:hover td{background:#1c2128;}
    .lc-perf-bar-wrap{display:flex;align-items:center;gap:8px;}
    .lc-perf-bar-bg{flex:1;height:10px;background:#21262d;border-radius:5px;overflow:hidden;}
    .lc-perf-bar-fill{height:100%;border-radius:5px;transition:width .8s ease;}
    .lc-perf-pct{font-family:'Courier New',monospace;font-size:12px;min-width:40px;text-align:right;}
    .lc-zoom-row{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px;align-items:center;}
    .lc-zoom-btn{padding:5px 12px;border-radius:6px;border:1px solid #30363d;background:transparent;color:#8b949e;cursor:pointer;font-size:11px;transition:all .15s;}
    .lc-zoom-btn:hover{border-color:#58a6ff;color:#58a6ff;background:#58a6ff11;}
    .lc-loader{display:flex;align-items:center;justify-content:center;height:200px;color:#8b949e;font-size:14px;gap:10px;}
    .lc-spin{width:20px;height:20px;border:2px solid #30363d;border-top-color:#58a6ff;border-radius:50%;animation:lcspin .8s linear infinite;}
    @keyframes lcspin{to{transform:rotate(360deg)}}
    .lc-empty{padding:32px;color:#8b949e;text-align:center;font-size:14px;}
    .lc-debug{margin-top:10px;padding:8px 12px;background:#1c2128;border:1px solid #30363d;border-radius:6px;font-family:monospace;font-size:11px;color:#444;}
    .lc-reload-btn{margin-top:12px;padding:7px 20px;background:#58a6ff22;border:1px solid #58a6ff;color:#58a6ff;border-radius:8px;cursor:pointer;font-size:13px;}
</style>

<div id="lcRoot" class="lc-dashboard">
    <div class="lc-loader"><div class="lc-spin"></div>Lade Leistungsdaten ...</div>
</div>

<script>
(function () {
    let _daten=null, _ansicht='pakete', _chartZeit=null, _chartPak=null, _chartLeist=null;
    const FARBEN=['#58a6ff','#3fb950','#f0883e','#c0a4ff','#e3b341','#f85149','#39d353','#79c0ff','#ffa657','#d2a8ff','#56d364','#ff7b72'];
    const C={muted:'#8b949e',border:'#30363d',pack:'#3fb950',takte:'#58a6ff',warn:'#e3b341',neg:'#f85149'};

    // ── Filter lesen ─────────────────────────────────────────────────────────
    function leseFilter() {
        if (typeof updateDate==='function') { try{updateDate('Von');updateDate('Bis');}catch(e){} }
        let von=document.getElementById('DatumVon')?.value||'';
        let bis=document.getElementById('DatumBis')?.value||'';
        let mid=document.getElementById('MaschinenId')?.value||'0';
        if (!von) { const d=document.getElementById('vonDay')?.value,m=document.getElementById('vonMonth')?.value,y=document.getElementById('vonYear')?.value; if(d&&m&&y) von=y+'-'+String(m).padStart(2,'0')+'-'+String(d).padStart(2,'0'); }
        if (!bis) { const d=document.getElementById('bisDay')?.value,m=document.getElementById('bisMonth')?.value,y=document.getElementById('bisYear')?.value; if(d&&m&&y) bis=y+'-'+String(m).padStart(2,'0')+'-'+String(d).padStart(2,'0'); }
        console.log('[LeistungChart] Filter:',{von,bis,mid});
        return {datumVon:von,datumBis:bis,maschinenId:mid};
    }

    // ── Laden ────────────────────────────────────────────────────────────────
    window.ladeLeistungChart = function(force) {
        if (_daten&&!force) return;
        _daten=null;
        document.getElementById('lcRoot').innerHTML='<div class="lc-loader"><div class="lc-spin"></div>Lade Leistungsdaten ...</div>';
        const f=leseFilter(), qs=[];
        if (f.datumVon) qs.push('datumVon='+encodeURIComponent(f.datumVon));
        if (f.datumBis) qs.push('datumBis='+encodeURIComponent(f.datumBis));
        if (f.maschinenId&&f.maschinenId!=='0') qs.push('maschinenId='+encodeURIComponent(f.maschinenId));
        const url='/Leistungsdaten/GetChartData'+(qs.length?'?'+qs.join('&'):'');
        fetch(url,{headers:{'X-Requested-With':'XMLHttpRequest'}})
            .then(r=>{if(!r.ok)throw new Error('HTTP '+r.status);return r.json();})
            .then(json=>{_daten=json;if(!json.zeitreihe||json.zeitreihe.length===0){zeigeLeer(json,url);return;}renderDashboard();})
            .catch(err=>{document.getElementById('lcRoot').innerHTML=`<div class="lc-empty"><div style="font-size:28px;color:#f85149;margin-bottom:8px">&#10060;</div><div style="color:#e6edf3;margin-bottom:6px">Fehler beim Laden</div><div class="lc-debug">${err.message}</div><button class="lc-reload-btn" onclick="ladeLeistungChart(true)">&#128260; Neu laden</button></div>`;});
    };
    window.lcNeuLaden=()=>ladeLeistungChart(true);

    function zeigeLeer(json,url) {
        const d=json.debug||{};
        document.getElementById('lcRoot').innerHTML=`
            <div class="lc-empty">
                <div style="font-size:36px;margin-bottom:10px">&#128219;</div>
                <div style="font-size:16px;color:#e6edf3;margin-bottom:6px">Keine Daten im Zeitraum</div>
                <div style="font-size:13px">Datum/Maschine anpassen &rarr; <strong style="color:#58a6ff">Filtern</strong> &rarr; Tab wechseln</div>
                <div class="lc-debug">
                    Zeitraum: <span style="color:#58a6ff">${d.datumVon||'?'}</span> &ndash; <span style="color:#58a6ff">${d.datumBis||'?'}</span>
                    &nbsp;&middot;&nbsp; Maschine: <span style="color:#f0883e">${d.maschinenId||'alle'}</span>
                    &nbsp;&middot;&nbsp; Zeilen: <span style="color:#f85149">${d.gesamtDatensaetze??0}</span>
                </div>
                <button class="lc-reload-btn" onclick="lcNeuLaden()">&#128260; Neu laden</button>
            </div>`;
    }

    // ── Dashboard ────────────────────────────────────────────────────────────
    function renderDashboard() {
        const d=_daten, dbg=d.debug||{}, lp=d.leistungProzent||[], prog=d.programme||[];
        const gesPack=lp.reduce((s,p)=>s+p.packungen,0);
        const gesTakte=lp.reduce((s,p)=>s+p.takteSumme,0);
        const topLeist=lp[0]||{};
        const tage=new Set((d.tagesPackungen||[]).map(x=>x.datum)).size;

        function stat(label,val,col,sub){return `<div class="lc-stat"><div class="lc-stat-label">${label}</div><div class="lc-stat-val" style="color:${col}">${val}</div><div class="lc-stat-sub">${sub}</div></div>`;}

        document.getElementById('lcRoot').innerHTML=`
            <div class="lc-header">
                <h4>&#9889; Leistungs-Analyse</h4>
                <p>${dbg.datumVon||'?'} &ndash; ${dbg.datumBis||'?'} &nbsp;&middot;&nbsp; ${lp.length} Programme &nbsp;&middot;&nbsp; ${tage} Tage</p>
            </div>
            <div class="lc-stat-grid">
                ${stat('Pakete gesamt',gesPack.toLocaleString('de-DE'),C.pack,'Alle Programme')}
                ${stat('Takte gesamt',gesTakte.toLocaleString('de-DE'),C.takte,'Maschinentakte')}
                ${stat('&#216; Pakete/Tag',tage>0?Math.round(gesPack/tage).toLocaleString('de-DE'):'&ndash;',C.warn,'Tagesdurchschnitt')}
                ${stat('Top Leistung',topLeist.name||'&ndash;','#c0a4ff',topLeist.leistungPct!=null?topLeist.leistungPct+'%':'')}
                ${stat('Tage',tage,C.muted,'im Zeitraum')}
            </div>
            <div class="lc-tabs">
                <button class="lc-tab-btn active" id="lcTab_pakete" onclick="lcWechselTab('pakete')">&#128230; Pakete / Tag / Programm</button>
                <button class="lc-tab-btn"         id="lcTab_leist"  onclick="lcWechselTab('leist')">&#128202; Leistung %</button>
                <button class="lc-tab-btn"         id="lcTab_zeit"   onclick="lcWechselTab('zeit')">&#128200; Zeitverlauf (Zoom)</button>
            </div>
            <div id="lcPane_pakete"></div>
            <div id="lcPane_leist"  style="display:none"></div>
            <div id="lcPane_zeit"   style="display:none"></div>
        `;
        bauePaketePane();
        baueLeistPane();
        baueZeitPane();
    }

    window.lcWechselTab=function(tab){
        _ansicht=tab;
        ['pakete','leist','zeit'].forEach(t=>{
            document.getElementById('lcPane_'+t).style.display=(t===tab)?'':'none';
            const btn=document.getElementById('lcTab_'+t);
            if(btn){btn.classList.toggle('active',t===tab);btn.style.background=t===tab?'#58a6ff22':'';btn.style.borderColor=t===tab?'#58a6ff':'#30363d';btn.style.color=t===tab?'#58a6ff':'#8b949e';}
        });
        if(tab==='zeit'&&!_chartZeit) baueZeitChart();
    };

    // ════════════════════════════════════════════════════════════════════════
    // TAB 1 — Pakete pro Tag pro Programm
    // ════════════════════════════════════════════════════════════════════════
    function bauePaketePane(){
        const pane=document.getElementById('lcPane_pakete');
        const tp=_daten.tagesPackungen||[];
        const lp=_daten.leistungProzent||[];
        const tage=[...new Set(tp.map(x=>x.datum))].sort();
        const prNummern=[...new Set(tp.map(x=>x.prNummer))];
        const maxPak=tp.length>0?Math.max(...tp.map(x=>x.packungen)):1;
        const hoehe=Math.max(280,tage.length*40+60);

        const datasets=prNummern.map((pr,i)=>{
            const progInfo=lp.find(p=>p.prNummer===pr);
            const col=FARBEN[i%FARBEN.length];
            return {
                label:progInfo?.name||'PR'+pr,
                data:tage.map(tag=>{const e=tp.find(x=>x.datum===tag&&x.prNummer===pr);return e?.packungen||0;}),
                backgroundColor:col+'cc',borderColor:col,borderWidth:1,borderRadius:3,prNummer:pr
            };
        });

        pane.innerHTML=`
            <div class="lc-box">
                <div class="lc-box-title">&#128230; Pakete pro Tag pro Programm</div>
                <div class="lc-box-hint">Jede Farbe = ein Programm &middot; Gestapelter Balken = Tagesgesamtleistung</div>
                <div style="position:relative;height:${hoehe}px"><canvas id="lcPakCanvas"></canvas></div>
            </div>
            <div class="lc-box">
                <div class="lc-box-title">&#128203; Tagesdetails</div>
                <div style="overflow-x:auto">
                    <table class="lc-perf-table">
                        <thead><tr><th>Tag</th><th>Programm</th><th style="text-align:right">Pakete</th><th style="text-align:right">Takte</th><th style="min-width:150px">Anteil</th></tr></thead>
                        <tbody>${tp.map((row)=>{
                            const prIdx=prNummern.indexOf(row.prNummer);
                            const col=FARBEN[prIdx%FARBEN.length];
                            const pct=Math.round(row.packungen/maxPak*100);
                            return `<tr>
                                <td style="white-space:nowrap;font-family:monospace;font-size:12px">${row.datum}</td>
                                <td><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${col};margin-right:6px"></span>${row.name||'PR'+row.prNummer}</td>
                                <td style="text-align:right;font-family:'Courier New',monospace;font-weight:700;color:${col}">${row.packungen.toLocaleString('de-DE')}</td>
                                <td style="text-align:right;font-family:'Courier New',monospace;color:#8b949e">${row.takte.toLocaleString('de-DE')}</td>
                                <td><div class="lc-perf-bar-wrap"><div class="lc-perf-bar-bg"><div class="lc-perf-bar-fill" style="width:${pct}%;background:${col}"></div></div><span class="lc-perf-pct" style="color:${col}">${pct}%</span></div></td>
                            </tr>`;
                        }).join('')}</tbody>
                    </table>
                </div>
            </div>
        `;

        if(_chartPak){_chartPak.destroy();_chartPak=null;}
        const canvas=document.getElementById('lcPakCanvas');
        if(canvas&&tage.length>0){
            Chart.defaults.color=C.muted;
            _chartPak=new Chart(canvas.getContext('2d'),{
                type:'bar',
                data:{labels:tage,datasets},
                options:{
                    indexAxis:'y',responsive:true,maintainAspectRatio:false,animation:{duration:500},
                    plugins:{
                        legend:{labels:{color:C.muted,font:{size:11},boxWidth:14}},
                        tooltip:{backgroundColor:'#0d1117ee',borderColor:C.border,borderWidth:1,titleColor:C.muted,bodyColor:'#e6edf3',
                            callbacks:{title:items=>'&#128197; '+items[0].label,label:ctx=>` ${ctx.dataset.label}: ${ctx.parsed.x.toLocaleString('de-DE')} Pakete`}}
                    },
                    scales:{
                        x:{stacked:true,ticks:{color:C.muted,font:{size:10}},grid:{color:C.border+'44'},title:{display:true,text:'Pakete',color:C.muted}},
                        y:{stacked:true,ticks:{color:'#e6edf3',font:{size:11}},grid:{display:false}}
                    }
                }
            });
        }
    }

    // ════════════════════════════════════════════════════════════════════════
    // TAB 2 — Leistung % pro Programm
    // ════════════════════════════════════════════════════════════════════════
    function baueLeistPane(){
        const pane=document.getElementById('lcPane_leist');
        const lp=_daten.leistungProzent||[];
        const hoehe=Math.max(250,lp.length*36+60);

        pane.innerHTML=`
            <div class="lc-box">
                <div class="lc-box-title">&#128202; Leistung % pro Programm</div>
                <div class="lc-box-hint">100% = bestes Programm im Zeitraum &middot; Farbe: &#128994; &ge;80% &nbsp; &#128993; &ge;50% &nbsp; &#128308; &lt;50%</div>
                <div style="display:grid;grid-template-columns:1fr 1.6fr;gap:16px;align-items:start">
                    <div style="position:relative;height:${hoehe}px"><canvas id="lcLeistCanvas"></canvas></div>
                    <table class="lc-perf-table">
                        <thead><tr><th>#</th><th>Programm</th><th style="text-align:right">Pakete</th><th style="min-width:160px">Leistung</th></tr></thead>
                        <tbody>${lp.map((p,i)=>{
                            const col=FARBEN[i%FARBEN.length];
                            const pct=p.leistungPct||0;
                            const lCol=pct>=80?C.pack:pct>=50?C.warn:C.neg;
                            return `<tr>
                                <td style="color:#555;font-size:11px;font-family:monospace">${i+1}</td>
                                <td><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${col};margin-right:6px"></span>${p.name||'PR'+p.prNummer}<div style="font-size:10px;color:#8b949e">${p.packungen.toLocaleString('de-DE')} Pakete</div></td>
                                <td style="text-align:right;font-family:'Courier New',monospace;color:${C.pack}">${p.packungen.toLocaleString('de-DE')}</td>
                                <td><div class="lc-perf-bar-wrap"><div class="lc-perf-bar-bg"><div class="lc-perf-bar-fill" style="width:${pct}%;background:${lCol}"></div></div><span class="lc-perf-pct" style="color:${lCol};font-weight:700">${pct}%</span></div></td>
                            </tr>`;
                        }).join('')}</tbody>
                    </table>
                </div>
            </div>
        `;

        if(_chartLeist){_chartLeist.destroy();_chartLeist=null;}
        const canvas=document.getElementById('lcLeistCanvas');
        if(canvas&&lp.length>0){
            const bgCols=lp.map(p=>{const pct=p.leistungPct||0;return pct>=80?C.pack+'cc':pct>=50?C.warn+'cc':C.neg+'cc';});
            const brCols=lp.map(p=>{const pct=p.leistungPct||0;return pct>=80?C.pack:pct>=50?C.warn:C.neg;});
            _chartLeist=new Chart(canvas.getContext('2d'),{
                type:'bar',
                data:{labels:lp.map(p=>p.name||'PR'+p.prNummer),datasets:[{label:'Leistung %',data:lp.map(p=>p.leistungPct),backgroundColor:bgCols,borderColor:brCols,borderWidth:1,borderRadius:4}]},
                options:{
                    indexAxis:'y',responsive:true,maintainAspectRatio:false,animation:{duration:600},
                    plugins:{legend:{display:false},tooltip:{backgroundColor:'#0d1117ee',borderColor:C.border,borderWidth:1,titleColor:C.muted,bodyColor:'#e6edf3',
                        callbacks:{label:ctx=>[`  Leistung: ${ctx.parsed.x}%`,`  Pakete: ${lp[ctx.dataIndex].packungen.toLocaleString('de-DE')}`,`  Takte: ${lp[ctx.dataIndex].takteSumme.toLocaleString('de-DE')}`]}}},
                    scales:{
                        x:{min:0,max:100,ticks:{color:C.muted,font:{size:10},callback:v=>v+'%'},grid:{color:C.border+'44'},title:{display:true,text:'Leistung (%)',color:C.muted}},
                        y:{ticks:{color:'#e6edf3',font:{size:11},crossAlign:'far'},grid:{display:false}}
                    }
                }
            });
        }
    }

    // ════════════════════════════════════════════════════════════════════════
    // TAB 3 — Zeitverlauf mit Zoom
    // ════════════════════════════════════════════════════════════════════════
    function baueZeitPane(){
        document.getElementById('lcPane_zeit').innerHTML=`
            <div class="lc-box">
                <div class="lc-box-title">&#128200; Maschinentakte &uuml;ber Zeit</div>
                <div class="lc-box-hint">&#128432; Maus ziehen = zoomen &nbsp;&middot;&nbsp; Doppelklick = zur&uuml;cksetzen &nbsp;&middot;&nbsp; Scroll = rein/rauszoomen</div>
                <div class="lc-zoom-row">
                    <button class="lc-zoom-btn" onclick="lcZoomReset()">&#128260; Zur&uuml;cksetzen</button>
                    <button class="lc-zoom-btn" onclick="lcZoomLetzte('1h')">1 Stunde</button>
                    <button class="lc-zoom-btn" onclick="lcZoomLetzte('6h')">6 Stunden</button>
                    <button class="lc-zoom-btn" onclick="lcZoomLetzte('1d')">1 Tag</button>
                </div>
                <div style="position:relative;height:320px"><canvas id="lcZeitCanvas"></canvas></div>
            </div>
        `;
    }

    function baueZeitChart(){
        if(_chartZeit){_chartZeit.destroy();_chartZeit=null;}
        const canvas=document.getElementById('lcZeitCanvas');
        if(!canvas) return;
        const punkte=_daten.zeitreihe||[];
        Chart.defaults.color=C.muted;
        _chartZeit=new Chart(canvas.getContext('2d'),{
            type:'line',
            data:{labels:punkte.map(p=>p.ts),datasets:[
                {label:'Maschinentakte',data:punkte.map(p=>p.takte),borderColor:C.takte,backgroundColor:C.takte+'22',borderWidth:2,pointRadius:punkte.length<100?3:0,pointHoverRadius:5,fill:true,tension:0.3},
                {label:'Packungen',data:punkte.map(p=>p.packungen),borderColor:C.pack,backgroundColor:'transparent',borderWidth:1.5,pointRadius:0,fill:false,tension:0.3,borderDash:[4,3]}
            ]},
            options:{
                responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},animation:{duration:300},
                plugins:{
                    legend:{labels:{color:C.muted,font:{size:12},boxWidth:20}},
                    tooltip:{backgroundColor:'#0d1117ee',borderColor:C.border,borderWidth:1,titleColor:C.muted,bodyColor:'#e6edf3',
                        callbacks:{title:items=>'&#128336; '+items[0].label,label:ctx=>` ${ctx.dataset.label}: ${ctx.parsed.y.toLocaleString('de-DE')}`}},
                    zoom:{pan:{enabled:true,mode:'x'},zoom:{wheel:{enabled:true},pinch:{enabled:true},drag:{enabled:true,backgroundColor:'#58a6ff22',borderColor:'#58a6ff',borderWidth:1},mode:'x'}}
                },
                scales:{
                    x:{ticks:{color:C.muted,maxTicksLimit:12,font:{size:10}},grid:{color:C.border+'44'}},
                    y:{ticks:{color:C.muted,font:{size:10}},grid:{color:C.border+'44'},title:{display:true,text:'Takte',color:C.muted}}
                }
            }
        });
    }

    window.lcZoomReset=()=>_chartZeit?.resetZoom();
    window.lcZoomLetzte=function(b){
        if(!_chartZeit||!_daten.zeitreihe.length) return;
        const n=_daten.zeitreihe.length-1;
        const offset=b==='1h'?Math.max(0,n-12):b==='6h'?Math.max(0,n-72):Math.max(0,n-288);
        _chartZeit.zoomScale('x',{min:offset,max:n},'default');
    };

})();
</script>
