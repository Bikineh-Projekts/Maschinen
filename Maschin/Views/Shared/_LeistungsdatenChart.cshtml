<div style="background:#0f172a;color:white;padding:20px;font-family:sans-serif;min-height:100vh;">

    <!-- KPI -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:15px;margin-bottom:20px;">
        <div class="kpi">Total Takte<br><span id="kpiTotal">-</span></div>
        <div class="kpi">Avg Takte<br><span id="kpiAvg">-</span></div>
        <div class="kpi">Max Takte<br><span id="kpiMax">-</span></div>
        <div class="kpi">Maschinen<br><span id="kpiMaschinen">-</span></div>
    </div>

    <!-- MAIN CHART -->
    <div class="box">
        <canvas id="mainChart"></canvas>
    </div>

    <!-- SECOND CHART -->
    <div class="box">
        <canvas id="hourChart"></canvas>
    </div>

    <!-- TABLE -->
    <div class="box">
        <table style="width:100%;border-collapse:collapse;">
            <thead>
                <tr>
                    <th>Zeit</th>
                    <th>Takte</th>
                    <th>Programm</th>
                </tr>
            </thead>
            <tbody id="tableBody"></tbody>
        </table>
    </div>

</div>

<style>
.kpi {
    background:#1e293b;
    padding:15px;
    border-radius:10px;
    text-align:center;
}
.kpi span {
    font-size:22px;
    font-weight:bold;
}
.box {
    background:#1e293b;
    padding:20px;
    border-radius:12px;
    margin-bottom:20px;
}
table th, table td {
    padding:8px;
    border-bottom:1px solid #334155;
    text-align:left;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/hammerjs"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom"></script>

<script>
let mainChart = null;
let hourChart = null;

async function loadDashboard() {

    try {
        const res = await fetch('/Leistungsdaten/GetChartData');
        const data = await res.json();

        // 🔴 FIX: handle empty data safely
        if (!data || !data.zeitreihe || data.zeitreihe.length === 0) {
            document.getElementById("mainChart").parentElement.innerHTML =
                "<div style='text-align:center;padding:40px'>Keine Daten vorhanden</div>";
            return;
        }

        // ================= KPI =================
        const takte = data.zeitreihe.map(x => x.takte);

        document.getElementById("kpiTotal").innerText =
            takte.reduce((a,b)=>a+b,0);

        document.getElementById("kpiAvg").innerText =
            Math.round(takte.reduce((a,b)=>a+b,0)/takte.length);

        document.getElementById("kpiMax").innerText =
            Math.max(...takte);

        document.getElementById("kpiMaschinen").innerText =
            data.maschinen ? data.maschinen.length : 0;

        // ================= GROUP =================
        const grouped = {};

        data.zeitreihe.forEach(x=>{
            const key = x.prNummer || "N/A";
            if(!grouped[key]) grouped[key]=[];
            grouped[key].push(x);
        });

        const labels = data.zeitreihe.map(x=>x.ts);

        const datasets = Object.keys(grouped).map((k,i)=>({
            label:"PR "+k,
            data: grouped[k].map(x=>x.takte),
            tension:0.3,
            borderWidth:2
        }));

        // ================= MAIN CHART =================
        if(mainChart) mainChart.destroy();

        mainChart = new Chart(document.getElementById("mainChart"),{
            type:'line',
            data:{labels,datasets},
            options:{
                responsive:true,
                plugins:{
                    legend:{labels:{color:'white'}},
                    zoom:{
                        pan:{enabled:true,mode:'x'},
                        zoom:{wheel:{enabled:true},pinch:{enabled:true},mode:'x'}
                    }
                },
                scales:{
                    x:{ticks:{color:'white'}},
                    y:{ticks:{color:'white'},beginAtZero:true}
                }
            }
        });

        // ================= HOURLY =================
        const hourLabels = (data.stundenkurve || []).map(x=>x.label);
        const hourValues = (data.stundenkurve || []).map(x=>x.takte);

        if(hourChart) hourChart.destroy();

        hourChart = new Chart(document.getElementById("hourChart"),{
            type:'bar',
            data:{
                labels:hourLabels,
                datasets:[{
                    label:"Hourly Takte",
                    data:hourValues
                }]
            },
            options:{
                plugins:{legend:{labels:{color:'white'}}},
                scales:{
                    x:{ticks:{color:'white'}},
                    y:{ticks:{color:'white'}}
                }
            }
        });

        // ================= TABLE =================
        const tbody = document.getElementById("tableBody");
        tbody.innerHTML="";

        data.zeitreihe.slice(0,100).forEach(x=>{
            const row = `
                <tr>
                    <td>${x.ts}</td>
                    <td>${x.takte}</td>
                    <td>${x.programm}</td>
                </tr>`;
            tbody.insertAdjacentHTML("beforeend", row);
        });

    } catch (err) {
        console.error(err);
        document.body.innerHTML =
            "<div style='color:red;text-align:center;padding:40px'>Fehler beim Laden</div>";
    }
}

// LOAD
document.addEventListener("DOMContentLoaded", loadDashboard);

// 🔥 SAFE LIVE UPDATE (no crash)
setInterval(()=>{
    loadDashboard();
},10000);
</script>
