<div id="chartRoot" style="background:#0f172a;color:white;padding:20px;border-radius:12px;">

    <div class="box">
        <canvas id="mainChart"></canvas>
    </div>

    <div class="box">
        <canvas id="hourChart"></canvas>
    </div>

    <div class="box">
        <table class="table table-dark table-sm">
            <thead>
                <tr>
                    <th>Zeit</th>
                    <th>Takte</th>
                    <th>Programm</th>
                </tr>
            </thead>
            <tbody id="tableBody"></tbody>
        </table>
    </div>

</div>

<style>
.box {
    background:#1e293b;
    padding:20px;
    border-radius:12px;
    margin-bottom:20px;
}
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

let mainChart = null;
let hourChart = null;

function getFilters() {
    try {
        const d = document;

        return {
            von: `${d.querySelector('[name=StartTag]').value}.${d.querySelector('[name=StartMonat]').value}.${d.querySelector('[name=StartJahr]').value}`,
            bis: `${d.querySelector('[name=EndTag]').value}.${d.querySelector('[name=EndMonat]').value}.${d.querySelector('[name=EndJahr]').value}`,
            maschine: d.querySelector('[name=MaschinenId]')?.value || 0
        };
    } catch {
        return {
            von: "01.01.2024",
            bis: "31.12.2024",
            maschine: 0
        };
    }
}

async function loadDashboard() {

    try {

        const f = getFilters();

        const url = `/Leistungsdaten/GetChartData?datumVon=${f.von}&datumBis=${f.bis}&maschinenId=${f.maschine}`;

        const res = await fetch(url);

        if (!res.ok) throw new Error("HTTP");

        const data = await res.json();

        if (!data.zeitreihe || data.zeitreihe.length === 0) {
            document.getElementById("chartRoot").innerHTML =
                "<div style='text-align:center;padding:30px'>Keine Daten</div>";
            return;
        }

        // ===== MAIN =====
        if (mainChart) mainChart.destroy();

        mainChart = new Chart(document.getElementById("mainChart"), {
            type: 'line',
            data: {
                labels: data.zeitreihe.map(x => x.ts),
                datasets: [{
                    label: "Takte",
                    data: data.zeitreihe.map(x => x.takte)
                }]
            }
        });

        // ===== HOUR =====
        if (hourChart) hourChart.destroy();

        hourChart = new Chart(document.getElementById("hourChart"), {
            type: 'bar',
            data: {
                labels: data.stundenkurve.map(x => x.label),
                datasets: [{
                    label: "Hourly",
                    data: data.stundenkurve.map(x => x.takte)
                }]
            }
        });

        // ===== TABLE =====
        const tbody = document.getElementById("tableBody");
        tbody.innerHTML = "";

        data.zeitreihe.slice(0,50).forEach(x => {
            tbody.innerHTML += `
                <tr>
                    <td>${x.ts}</td>
                    <td>${x.takte}</td>
                    <td>${x.programm}</td>
                </tr>
            `;
        });

    } catch (e) {

        console.error(e);

        document.getElementById("chartRoot").innerHTML =
            "<div style='color:red;text-align:center;padding:30px'>Fehler beim Laden</div>";
    }
}

</script>
