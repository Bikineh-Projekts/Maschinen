# ===== API Keys =====
# Get your free API keys from:
# - Finnhub: https://finnhub.io/register
# - Alpha Vantage: https://www.alphavantage.co/support/#api-key
# - Twelve Data: https://twelvedata.com/pricing

FINNHUB_API_KEY=your_finnhub_api_key_here
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here
TWELVEDATA_API_KEY=your_twelvedata_api_key_here

# ===== PostgreSQL Connection =====
# These will be set as Environment Variables in Render
# DO NOT commit real credentials to GitHub!

PGHOST=your-postgres-host.render.com
PGPORT=5432
PGDATABASE=Marketdb
PGUSER=your_postgres_user
PGPASSWORD=your_postgres_password

# ===== Pipeline Configuration =====
# Comma-separated stock symbols to track
SYMBOLS=AAPL,MSFT,GOOGL,TSLA,AMZN

# How often to fetch data (in seconds)
# Recommended: 3600 (1 hour) due to API rate limits
POLL_INTERVAL_SECONDS=3600

# Max records to fetch from Alpha Vantage
ALPHA_MAX_RECORDS=10

# Output size for Twelve Data
TWELVE_OUTPUTSIZE=30
